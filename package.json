{
  "name": "@obinexusltd/cpolycall",
  "version": "1.0.0",
  "description": "Reference C binding for the libpolycall 1.5.0 FFI.",
  "keywords": [
    "c",
    "cmake",
    "libpolycall",
    "ffi",
    "native"
  ],
  "homepage": "https://github.com/obinexus/cpolycall#readme",
  "bugs": {
    "url": "https://github.com/obinexus/cpolycall/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obinexus/cpolycall.git"
  },
  "license": "MIT",
  "author": {
    "name": "Nnamdi Michael Okpala",
    "email": "okpalan@protonmail.com"
  },
  "type": "commonjs",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./src/*": "./src/*",
    "./include/*": "./include/*",
    "./generated/*": "./generated/*",
    "./examples/*": "./examples/*",
    "./cmake/*": "./cmake/*",
    "./config": "./cpolycallrc",
    "./manifest": "./polycall-binding.json",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "src/",
    "include/",
    "generated/",
    "examples/",
    "tests/",
    "scripts/",
    "cmake/",
    "CMakeLists.txt",
    "Makefile",
    "polycall-binding.json",
    "cpolycallrc",
    "README.md",
    "TODO.md"
  ],
  "directories": {
    "example": "examples",
    "lib": "lib",
    "test": "tests"
  },
  "scripts": {
    "build": "make",
    "clean": "make clean",
    "test": "make test && node tests/package.test.js",
    "verify": "make verify-dry",
    "prepack": "npm run test && npm run verify"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  }
}
